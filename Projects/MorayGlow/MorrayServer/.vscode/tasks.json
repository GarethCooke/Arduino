{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "PIO Test (native)",
            "type": "shell",
            "command": "${env:USERPROFILE}/.platformio/penv/Scripts/pio",
            "args": ["test", "-e", "native"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Client Tests (Jest)",
            "type": "shell",
            "command": "npm test",
            "options": {
                "cwd": "${workspaceFolder}/../MorrayClient"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Test Server Tests (Jest)",
            "type": "shell",
            "command": "npm test",
            "options": {
                "cwd": "${workspaceFolder}/../MorrayClient/test-server"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Run All Tests",
            "dependsOn": [
                "PIO Test (native)",
                "Client Tests (Jest)",
                "Test Server Tests (Jest)"
            ],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Start Test Server",
            "type": "shell",
            "command": "npm start",
            "options": {
                "cwd": "${workspaceFolder}/../MorrayClient/test-server"
            },
            "group": "build",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        }
    ]
}
